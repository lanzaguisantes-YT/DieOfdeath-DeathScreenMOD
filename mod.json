{
  "geode": "5.7.1",
  "gd": {
    "win": "2.2074",
    "android": "2.2074"
  },
  "id": "devai.optimization-menu",
  "name": "Optimization Menu",
  "version": "1.0.0",
  "developer": "DevAI",
  "description": "A simple optimization menu for Geometry Dash to improve performance.",
  "settings": {
    "disable-particles": {
      "type": "bool",
      "default": false,
      "name": "Disable Particles",
      "description": "Disables particle effects to improve FPS"
    },
    "disable-backgrounds": {
      "type": "bool",
      "default": false,
      "name": "Disable Backgrounds",
      "description": "Disables animated backgrounds"
    },
    "show-fps": {
      "type": "bool",
      "default": false,
      "name": "Show FPS Counter",
      "description": "Shows FPS counter on screen"
    },
    "fps-limit": {
      "type": "int",
      "default": 60,
      "min": 30,
      "max": 360,
      "name": "FPS Limit",
      "description": "Set maximum FPS limit"
    }
  }
}
